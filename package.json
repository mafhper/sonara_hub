{
  "name": "sonara-hub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "node server/index.mjs",
    "dev:server:watch": "node --watch server/index.mjs",
    "build": "npm run type-check && vite build",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "node --test tests/*.test.mjs",
    "test:ui": "node tests/ui-smoke.mjs && node tests/project-folder-flow.mjs",
    "test:scale": "node tests/scale-memory.test.mjs",
    "test:flow": "node tests/full-flow-smoke.mjs",
    "test:render": "node tests/render-presets-smoke.mjs",
    "bench:render": "node tests/render-benchmark.mjs",
    "bench:render:full": "npm run bench:render -- --profile=full",
    "bench:render:audio": "npm run bench:render -- --audio=input",
    "bench:workflow:e2e": "node tests/workflow-e2e-benchmark.mjs",
    "test:release": "npm run format:check && npm run type-check && npm test && npm run build && npm run test:ui && npm run test:flow && npm run test:render && npm run site:build && npm run site:test",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "site:dev": "vite --config site/vite.config.ts --host 127.0.0.1",
    "site:build": "tsc --noEmit -p site/tsconfig.json && vite build --config site/vite.config.ts",
    "site:preview": "vite preview --config site/vite.config.ts --host 127.0.0.1",
    "site:test": "node tests/site-smoke.mjs",
    "app": "npm run build && npm run start",
    "start": "node server/index.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.8.0",
    "ffmpeg-static": "^5.2.0",
    "lucide-react": "^1.17.0",
    "multer": "^2.0.2",
    "music-metadata": "^11.10.3",
    "node-id3": "^0.2.9",
    "playwright": "^1.60.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sharp": "^0.34.3",
    "vite": "^7.1.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  }
}
